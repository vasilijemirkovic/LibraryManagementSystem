<Window x:Class="LibraryManagementSystem.View.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Report" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <TextBlock Text="Library Report"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#4C9BE8" Margin="0,0,0,20"/>

        <Border Background="#2E2E3E" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalCount" Text="0" FontSize="32"
                               FontWeight="Bold" Foreground="#4C9BE8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Total" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="AvailableCount" Text="0" FontSize="32"
                               FontWeight="Bold" Foreground="#6BFF8E"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Available" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>

</Window>

<Window x:Class="LibraryManagementSystem.View.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Report" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">

        <TextBlock Text="Library Report"
                   FontSize="20" FontWeight="Bold"
                   Foreground="#4C9BE8" Margin="0,0,0,20"/>

        <Border Background="#2E2E3E" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="TotalCount" Text="0" FontSize="32"
                               FontWeight="Bold" Foreground="#4C9BE8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Total" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock x:Name="AvailableCount" Text="0" FontSize="32"
                               FontWeight="Bold" Foreground="#6BFF8E"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Available" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="BorrowedCount" Text="0" FontSize="32"
                               FontWeight="Bold" Foreground="#FF6B6B"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Borrowed" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="#2E2E3E" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="Overview" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Available"/>
                    <Border Grid.Column="1" Height="20" CornerRadius="4"
                    Background="#2E2E3E" Margin="5,0">
                        <Border x:Name="AvailableBar" HorizontalAlignment="Left"
                        Height="20" CornerRadius="4" Background="#6BFF8E"/>
                    </Border>
                    <TextBlock Grid.Column="2" x:Name="AvailablePercent"
                       HorizontalAlignment="Right"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Borrowed"/>
                    <Border Grid.Column="1" Height="20" CornerRadius="4"
                    Background="#2E2E3E" Margin="5,0">
                        <Border x:Name="BorrowedBar" HorizontalAlignment="Left"
                        Height="20" CornerRadius="4" Background="#FF6B6B"/>
                    </Border>
                    <TextBlock Grid.Column="2" x:Name="BorrowedPercent"
                       HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
<Window x:Class="LibraryManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem"
        mc:Ignorable="d"
        Title="Library Management System" Height="600" Width="900"
        Background="#1E1E2E">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A8AD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
    </Window.Resources>


    <StackPanel Margin="10,0,10,10" Height="414" VerticalAlignment="Bottom">

        <TextBox x:Name="TitleBox" Margin="5"/>
        <TextBox x:Name="AuthorBox" Margin="5"/>

        <Button Content="Add Book" Click="AddBook_Click" Margin="5"/>
        <Button Content="Edit Book" Click="EditBook_Click" Margin="5"/>
        <Button Content="Delete Book" Click="DeleteBook_Click" Margin="5"/>
        <Button Content="Borrow Book" Click="BorrowBook_Click" Margin="5"/>
        <Button Content="Return Book" Click="ReturnBook_Click" Margin="5"/>

        <TextBox x:Name="SearchBox" Margin="5" TextChanged="SearchBox_TextChanged"/>

        <DataGrid ItemsSource="{Binding FilteredBooks}" SelectedItem="{Binding SelectedBook}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" SortMemberPath="Title" />
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" SortMemberPath="Author" />
                <DataGridTextColumn Header="Available" Binding="{Binding Status}" SortMemberPath="Status" />
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
</Window>

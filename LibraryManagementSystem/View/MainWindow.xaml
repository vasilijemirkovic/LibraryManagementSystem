<Window x:Class="LibraryManagementSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem"
        mc:Ignorable="d"
        Title="Library Management System" Height="600" Width="900"
        Background="#1E1E2E">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A8AD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="RowBackground" Value="#2E2E3E"/>
            <Setter Property="AlternatingRowBackground" Value="#3A3A4E"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

        
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Library Management System"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#4C9BE8" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TitleBox" Grid.Column="0" Margin="0,0,10,0"/>
            <TextBox x:Name="AuthorBox" Grid.Column="1" Margin="0,0,10,0"/>
            <Button Grid.Column="2" Content="Add Book" Width="100" Click="AddBook_Click"
        </Grid>
            
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0" Content="Edit Book" Width="100" Margin="0,0,10,0" Click="EditBook_Click"/>
        <Button Grid.Column="1" Content="Delete Book" Width="100" Margin="0,0,10,0" Click="DeleteBook_Click"/>
        <Button Grid.Column="2" Content="Borrow / Return" Width="120" Margin="0,0,10,0" Click="BorrowReturn_Click"/>
        <TextBox x:Name="SearchBox" Grid.Column="3" Margin="0,0,10,0" TextChanged="SearchBox_TextChanged"/>
        <ComboBox x:Name="StatusFilter" Grid.Column="4" SelectionChanged="StatusFilter_SelectionChanged">
            <ComboBoxItem Content="All" IsSelected="True"/>
            <ComboBoxItem Content="Available"/>
            <ComboBoxItem Content="Borrowed"/>
        </ComboBox>



                </Grid>


        <StackPanel Margin="10,0,10,10" Height="414" VerticalAlignment="Bottom">

        <TextBox x:Name="TitleBox" Margin="5"/>
        <TextBox x:Name="AuthorBox" Margin="5"/>

        <Button Content="Add Book" Click="AddBook_Click" Margin="5"/>
        <Button Content="Edit Book" Click="EditBook_Click" Margin="5"/>
        <Button Content="Delete Book" Click="DeleteBook_Click" Margin="5"/>
        <Button Content="Borrow Book" Click="BorrowBook_Click" Margin="5"/>
        <Button Content="Return Book" Click="ReturnBook_Click" Margin="5"/>

        <TextBox x:Name="SearchBox" Margin="5" TextChanged="SearchBox_TextChanged"/>

        <DataGrid ItemsSource="{Binding FilteredBooks}" SelectedItem="{Binding SelectedBook}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" />
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" SortMemberPath="Title" />
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" SortMemberPath="Author" />
                <DataGridTextColumn Header="Available" Binding="{Binding Status}" SortMemberPath="Status" />
            </DataGrid.Columns>
        </DataGrid>

    </StackPanel>
</Window>

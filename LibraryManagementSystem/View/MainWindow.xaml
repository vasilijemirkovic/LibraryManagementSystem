<Window x:Class="LibraryManagementSystem.MainWindow" FontFamily="Segoe UI" FontSize="13"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem.View"
        mc:Ignorable="d"
        Title="Library Management System" Height="600" Width="900"
        Background="#1E1E2E">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="5,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A8AD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2E2E3E"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2E2E3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4C9BE8"/>
            <Setter Property="RowBackground" Value="#2E2E3E"/>
            <Setter Property="AlternatingRowBackground" Value="#3A3A4E"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#4C9BE8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Library Management System"
                   FontSize="22" FontWeight="Bold"
                   Foreground="#4C9BE8" Margin="0,0,0,16"/>

        <!-- Book inserting -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TitleBox" Grid.Column="0" Margin="0,0,8,0"/>
            <TextBox x:Name="AuthorBox" Grid.Column="1" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Add Book" Width="100" Click="AddBook_Click"/>
        </Grid>

        <!-- Button and searching -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Edit Book" Width="100" Margin="0,0,8,0" Click="EditBook_Click"/>
            <Button Grid.Column="1" Content="Delete Book" Width="100" Margin="0,0,8,0" Click="DeleteBook_Click"/>
            <Button Grid.Column="2" Content="Borrow / Return" Width="120" Margin="0,0,8,0" Click="BorrowReturn_Click"/>
            <Button Grid.Column="3" Content="Report" Width="100" Margin="0,0,8,0" Click="Report_Click"/>
            <TextBox x:Name="SearchBox" Grid.Column="4" Margin="0,0,8,0" TextChanged="SearchBox_TextChanged"/>
            <ComboBox x:Name="StatusFilter" Grid.Column="5" SelectionChanged="StatusFilter_SelectionChanged">
                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Available"/>
                <ComboBoxItem Content="Borrowed"/>
            </ComboBox>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding FilteredBooks}"
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBorrowed}" Value="True">
                            <Setter Property="Foreground" Value="#FF6B6B"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsBorrowed}" Value="False">
                            <Setter Property="Foreground" Value="#6BFF8E"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="*"/>
                <DataGridTextColumn Header="Available" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Borrowed Date" Binding="{Binding BorrowedDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
                <DataGridTextColumn Header="Due Date" Binding="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toast -->
        <local:ToastNotification x:Name="Toast" Grid.Row="4"
                                 HorizontalAlignment="Right"
                                 Margin="0,8,0,0"/>

        <!-- Status bar -->
        <Border Grid.Row="5" Background="#2E2E3E" Padding="10,5" Margin="0,8,0,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total books: " Foreground="#4C9BE8" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding TotalBooks}" Foreground="White"/>
                <TextBlock Text="  |  Available: " Foreground="#4C9BE8" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding AvailableBooks}" Foreground="#6BFF8E"/>
                <TextBlock Text="  |  Borrowed: " Foreground="#4C9BE8" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding BorrowedBooks}" Foreground="#FF6B6B"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
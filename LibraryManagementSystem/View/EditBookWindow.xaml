<Window x:Class="LibraryManagementSystem.View.EditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Book" Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="15">
        <TextBlock Text="Title:" Margin="0,0,0,3"/>
        <TextBox x:Name="TitleBox" Margin="0,0,0,10"/>

        <TextBlock Text="Author:" Margin="0,0,0,3"/>
        <TextBox x:Name="AuthorBox" Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="75" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Cancel" Width="75" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>